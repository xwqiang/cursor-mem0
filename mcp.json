{
  "mcpServers": {
    "cursor-mem": {
      "type": "stdio",
      "command": "uvx",
      "args": ["--python", "3.12", "--from", "cursor-mem0[mcp]", "cursor-mem-mcp"],
      "env": {
        "CURSOR_API_KEY": "${env:CURSOR_API_KEY}",
        "CURSOR_MEM_USER_ID": "${env:CURSOR_MEM_USER_ID}"
      },
      "envFile": "${workspaceFolder}/.env"
    }
  }
}
