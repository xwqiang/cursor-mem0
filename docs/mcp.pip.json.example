{
  "mcpServers": {
    "cursor-mem": {
      "type": "stdio",
      "command": "python3.12",
      "args": ["-m", "cursor_mem.mcp_server"],
      "env": {
        "CURSOR_API_KEY": "${env:CURSOR_API_KEY}",
        "CURSOR_MEM_USER_ID": "${env:CURSOR_MEM_USER_ID}"
      },
      "envFile": "${workspaceFolder}/.env"
    }
  }
}
